# --- Registry / discovery ----------------------------------------------------
# Point at your NMOS registry's Query API. Accepts a bare host, host:port, or a
# full versioned base URL. Leave UNSET to auto-discover via mDNS (_nmos-query._tcp).
NMOS_REGISTRY_URL=http://registry.local:8235
NMOS_QUERY_VERSION=v1.3
NMOS_CONNECTION_VERSION=v1.1
NMOS_MDNS_TIMEOUT=4.0

# --- Transport / TLS ----------------------------------------------------------
# Scheme assumed when only a host is discovered/given.
NMOS_USE_HTTPS=false
# true / false, or a path to a CA bundle to verify server certificates.
NMOS_VERIFY_TLS=true
NMOS_REQUEST_TIMEOUT=15.0

# --- IS-10 authorization (OAuth2 client_credentials) --------------------------
# Enable only for secured deployments that require bearer tokens.
NMOS_AUTH_ENABLED=false
NMOS_AUTH_TOKEN_URL=https://auth.local/oauth2/token
NMOS_AUTH_CLIENT_ID=
NMOS_AUTH_CLIENT_SECRET=
NMOS_AUTH_SCOPE=connection query
